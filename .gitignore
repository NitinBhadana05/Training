/vendor/bundle

# 🔹 Rails Logs & Temp
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# 🔹 Storage
/storage/*
!/storage/.keep

# 🔹 Database
/db/*.sqlite3
/db/*.sqlite3-journal

# 🔹 Environment
.env
.env.*
nitin/
nitin_env/

# 🔹 Node
/node_modules

# 🔹 Logs
*.log

# 🔹 System
.DS_Store
Thumbs.db

