generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ar_internal_metadata {
  key        String   @id @db.VarChar
  value      String?  @db.VarChar
  created_at DateTime @db.Timestamp(6)
  updated_at DateTime @db.Timestamp(6)
}

model bounties {
  id            BigInt     @id @default(autoincrement())
  created_at    DateTime   @db.Timestamp(6)
  last_seen     String?    @db.VarChar
  poster_image  String?    @db.VarChar
  reward_amount Int?
  status        String?    @db.VarChar
  target_name   String?    @db.VarChar
  threat_level  Int?
  updated_at    DateTime   @db.Timestamp(6)
  missions      missions[]
}

model hunters {
  id         BigInt     @id @default(autoincrement())
  alias      String?    @db.VarChar
  created_at DateTime   @db.Timestamp(6)
  rank       String?    @db.VarChar
  region     String?    @db.VarChar
  updated_at DateTime   @db.Timestamp(6)
  missions   missions[]
}

model missions {
  id         BigInt   @id @default(autoincrement())
  hunter_id  BigInt
  bounty_id  BigInt
  completed  Boolean?
  notes      String?
  created_at DateTime @db.Timestamp(6)
  updated_at DateTime @db.Timestamp(6)
  hunters    hunters  @relation(fields: [hunter_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_2dd92b903c")
  bounties   bounties @relation(fields: [bounty_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rails_41ab5c0440")

  @@index([bounty_id], map: "index_missions_on_bounty_id")
  @@index([hunter_id], map: "index_missions_on_hunter_id")
}

model schema_migrations {
  version String @id @db.VarChar
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?

  role          String    @default("user")

  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}