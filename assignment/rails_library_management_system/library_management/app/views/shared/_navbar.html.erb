<div class="navbar">
  <div>
    <%= link_to "Books", books_path %>
    <%= link_to "Issue", new_issue_path %>
    <%= link_to "Users", users_path %>
  </div>

  <div>
    <% if current_user %>
      Welcome <%= current_user.name %> |
      <%= link_to "Logout", logout_path, method: :delete %>
    <% else %>
      <%= link_to "Login", login_path %> |
      <%= link_to "Sign Up", signup_path %>
    <% end %>
  </div>
</div>