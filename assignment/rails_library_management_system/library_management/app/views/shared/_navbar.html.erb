<nav class="navbar">
  <div class="navbar__brand">
    <%= link_to root_path, class: "brand-mark" do %>
      <span class="brand-mark__badge">LS</span>
      <span>
        <strong>Library Stack</strong>
        <small>Manage books, members, and circulation.</small>
      </span>
    <% end %>
  </div>

  <div class="navbar__links">
    <% if current_user %>
      <%= link_to "Books", books_path(view: "books"), class: "nav-link" %>
      <%= link_to current_user.admin? ? "Issue Book" : "Rent Book", new_issue_path, class: "nav-link" %>
      <%= link_to current_user.admin? ? "Bills" : "My Bills", issues_path, class: "nav-link" %>
      <% if current_user.admin? %>
        <%= link_to "Members", users_path, class: "nav-link" %>
      <% end %>
      <div class="navbar__user">
        <span><%= current_user.name %></span>
        <%= button_to "Logout", logout_path, method: :delete, class: "button button--ghost" %>
      </div>
    <% else %>
      <%= link_to "Login", login_path, class: "nav-link" %>
      <%= link_to "Create account", signup_path, class: "button button--primary" %>
    <% end %>
  </div>
</nav>
