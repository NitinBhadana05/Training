<div class="container">
  <h1>Login</h1>

  <%= form_with url: login_path do %>
    <%= email_field_tag :email, nil, placeholder: "Email" %>
    <%= password_field_tag :password, nil, placeholder: "Password" %>
    <%= submit_tag "Login" %>
  <% end %>

  <%= link_to "Sign Up", signup_path, class: "link-btn" %>
</div>