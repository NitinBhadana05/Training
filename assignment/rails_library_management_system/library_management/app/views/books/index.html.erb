<section class="hero">
  <div>
    <p class="eyebrow">Library dashboard</p>
    <h1>Track the catalog and keep circulation visible.</h1>
    <p class="hero__copy">
      Search books, monitor issued titles, and move quickly between catalog work, billing, and member activity.
    </p>
  </div>

  <div class="hero__actions hero__actions--three">
    <% if current_user.admin? %>
      <%= link_to "Add Book", new_book_path, class: "button button--primary" %>
      <%= link_to "Issue Book", new_issue_path, class: "button button--secondary" %>
      <%= link_to "Show Bills", issues_path, class: "button button--ghost" %>
    <% else %>
      <%= link_to "Browse Books", books_path(view: "books"), class: "button button--primary" %>
      <%= link_to "Rent Book", new_issue_path, class: "button button--secondary" %>
      <%= link_to "My Bills", issues_path, class: "button button--ghost" %>
    <% end %>
  </div>
</section>

<%= render "stats", stats: @stats %>

<% if current_user.admin? %>
  <%= render "quick_new_book", book: @book %>
<% end %>

<section class="panel">
  <div class="panel__header">
    <div>
      <p class="eyebrow">Catalog</p>
      <h2><%= @show_all_books ? "All books" : "Recent books" %></h2>
    </div>

    <%= form_with url: books_path, method: :get, class: "search-form", data: { turbo_frame: "catalog_results", turbo_action: "advance", auto_search: true } do %>
      <%= hidden_field_tag :view, "books" %>
      <%= text_field_tag :q, @query, placeholder: "Search by title, author, or ISBN", autocomplete: "off", data: { auto_search_input: true } %>
      <%= submit_tag "Search", class: "button button--primary" %>
    <% end %>
  </div>

  <%= render "catalog_results", books: @books %>

  <% unless @show_all_books %>
    <div class="panel__footer">
      <%= link_to "View all books", books_path(view: "books"), class: "button button--primary" %>
    </div>
  <% end %>
</section>

<%= render "active_loans", active_issues: @active_issues %>
