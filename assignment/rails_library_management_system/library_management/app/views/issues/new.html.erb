<section class="form-shell">
  <div class="form-shell__intro">
    <p class="eyebrow">Circulation</p>
    <h1>Issue a book</h1>
    <p>Assign an available title to a member and record the issue date in one place.</p>
  </div>

  <article class="panel">
    <% if @available_books.any? %>
      <%= form_with model: @issue do |f| %>
        <div class="form-grid">
          <div class="field">
            <%= f.label :user_id, "Member" %>
            <%= f.collection_select :user_id, @users, :id, :name, { prompt: "Select a member" }, { selected: params.dig(:issue, :user_id) } %>
          </div>

          <div class="field">
            <%= f.label :book_id, "Available book" %>
            <%= f.collection_select :book_id, @available_books, :id, :title, { prompt: "Select a book" }, { selected: params.dig(:issue, :book_id) } %>
          </div>

          <div class="field field--full">
            <%= f.label :issue_date %>
            <%= f.date_field :issue_date, value: @issue.issue_date || Date.current %>
          </div>
        </div>

        <div class="form-actions">
          <%= link_to "Back", books_path, class: "button button--ghost" %>
          <%= f.submit "Issue book", class: "button button--primary" %>
        </div>
      <% end %>
    <% else %>
      <div class="empty-state">
        <h3>No books are available to issue.</h3>
        <p>Return a title first or add a new book to the catalog.</p>
        <div class="empty-state__actions">
          <%= link_to "View catalog", books_path, class: "button button--ghost" %>
          <%= link_to "Add book", new_book_path, class: "button button--primary" %>
        </div>
      </div>
    <% end %>
  </article>
</section>
