<%= form_with model: legend do |f| %>
  <% if legend.errors.any? %>
    <ul>
      <% legend.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :location %>
    <%= f.text_field :location %>
  </div>

  <div>
    <%= f.label :credibility_score %>
    <%= f.number_field :credibility_score %>
  </div>

  <%= f.submit %>
<% end %>
