<h1>Post Detail</h1>

<form action="/show" method="get">
  <input type="text" name="post_id" placeholder="Search id">
  <button type="submit">Show</button>
</form>





<% if @post %>
  <h2><%= @post.title %></h2>
  <p><%= @post.content %></p>

  <hr>

  <h3>Comments</h3>

  <% if @comments.any? %>
    <% @comments.each do |comment| %>
      <p><%= comment.body %></p>
    <% end %>
  <% else %>
    <p>No comments yet</p>
  <% end %>

<% else %>
  <p>Post not found</p>
<% end %>