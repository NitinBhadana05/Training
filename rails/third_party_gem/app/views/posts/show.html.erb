<p style="color: green"><%= notice %></p>

<%= render @post %>

<div>
  <% if policy(@post).update? %>
   <%= link_to "Edit this post", edit_post_path(@post) %> 
  <% end %>
  |
  <%= link_to "Back to posts", posts_path %>
  <% if policy(@post).destroy? %>
     <%= button_to "Destroy this post", @post, method: :delete %>
  <% end %>
 
</div>
