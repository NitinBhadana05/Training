<!-- app/views/bounties/_form.html.erb -->

<%= form_with model: @bounty,
    class: "space-y-6 rounded-2xl border border-gray-200 bg-white p-8 shadow-sm" do |f| %>

  <div>
    <%= f.label :target_name,
        class: "mb-2 block text-sm font-semibold text-gray-700" %>

    <%= f.text_field :target_name,
        class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-blue-500 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :threat_level,
        class: "mb-2 block text-sm font-semibold text-gray-700" %>

    <%= f.number_field :threat_level,
        class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-blue-500 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :last_seen,
        class: "mb-2 block text-sm font-semibold text-gray-700" %>

    <%= f.text_field :last_seen,
        class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-blue-500 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :reward_amount,
        class: "mb-2 block text-sm font-semibold text-gray-700" %>

    <%= f.number_field :reward_amount,
        class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-blue-500 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :status,
        class: "mb-2 block text-sm font-semibold text-gray-700" %>

    <%= f.select :status,
        [["Open", "open"], ["Captured", "captured"], ["Dead", "dead"]],
        {},
        class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-blue-500 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :poster_image,
        class: "mb-2 block text-sm font-semibold text-gray-700" %>

    <%= f.file_field :poster_image,
        class: "w-full rounded-xl border border-gray-300 px-4 py-3" %>
  </div>

  <%= f.submit class: "rounded-xl bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-500" %>

<% end %>