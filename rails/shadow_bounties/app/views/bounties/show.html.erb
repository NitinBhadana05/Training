<!-- app/views/bounties/show.html.erb -->

<div class="mx-auto max-w-5xl p-8">

  <div class="overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm">

    <% if @bounty.poster_image.present? %>
      <%= image_tag @bounty.poster_image.url,
          class: "h-[400px] w-full object-cover" %>
    <% end %>

    <div class="p-8">

      <div class="mb-8 flex items-center justify-between">

        <div>
          <h1 class="text-5xl font-bold text-gray-800">
            <%= @bounty.target_name %>
          </h1>

          <p class="mt-3 text-lg text-gray-500">
            Last Seen:
            <%= @bounty.last_seen %>
          </p>
        </div>

        <% if @bounty.status == "open" %>
          <span class="rounded-full bg-yellow-100 px-5 py-2 text-sm font-semibold text-yellow-700">
            OPEN
          </span>

        <% elsif @bounty.status == "captured" %>
          <span class="rounded-full bg-green-100 px-5 py-2 text-sm font-semibold text-green-700">
            CAPTURED
          </span>

        <% else %>
          <span class="rounded-full bg-red-100 px-5 py-2 text-sm font-semibold text-red-700">
            DEAD
          </span>
        <% end %>

      </div>

      <div class="grid gap-6 md:grid-cols-2">

        <div class="rounded-2xl bg-gray-50 p-6">
          <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-gray-500">
            Threat Level
          </h2>

          <p class="text-4xl font-bold text-gray-800">
            <%= @bounty.threat_level %>
          </p>
        </div>

        <div class="rounded-2xl bg-gray-50 p-6">
          <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-gray-500">
            Reward Amount
          </h2>

          <p class="text-4xl font-bold text-gray-800">
            $<%= @bounty.reward_amount %>
          </p>
        </div>

      </div>

      <div class="mt-10 flex flex-wrap gap-4">

        <%= link_to "Edit Bounty",
            edit_bounty_path(@bounty),
            class: "rounded-xl bg-yellow-500 px-6 py-3 font-medium text-white hover:bg-yellow-400" %>

        <%= link_to "Delete Bounty",
            @bounty,
            data: {
              turbo_method: :delete,
              turbo_confirm: "Delete this bounty?"
            },
            class: "rounded-xl bg-red-600 px-6 py-3 font-medium text-white hover:bg-red-500" %>

        <%= link_to "Back",
            bounties_path,
            class: "rounded-xl bg-gray-900 px-6 py-3 font-medium text-white hover:bg-gray-700" %>

      </div>

    </div>

  </div>

</div>