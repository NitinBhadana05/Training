<main class="mx-auto w-full max-w-7xl px-4 py-10 text-gray-900 sm:px-6 lg:px-8">
  <section class="rounded-3xl border border-gray-200 bg-gradient-to-r from-white via-indigo-50 to-sky-50 p-8 shadow-sm">
    <p class="text-sm uppercase tracking-[0.3em] text-indigo-300">Dashboard</p>
    <h1 class="mt-4 text-4xl font-bold tracking-tight text-gray-900">Manage hunters, bounties, and missions in one place.</h1>
    <p class="mt-4 max-w-2xl text-base text-gray-600">
      Use the navigation to browse each area, or open the create screen to add a new hunter, bounty, or mission.
    </p>
  </section>

  <section class="mt-8 grid gap-4 md:grid-cols-3">
    <%= link_to missions_path, class: "rounded-2xl border border-gray-200 bg-white p-6 transition hover:-translate-y-1 hover:border-indigo-400 hover:shadow-sm" do %>
      <p class="text-sm uppercase tracking-[0.3em] text-indigo-300">Missions</p>
      <h2 class="mt-3 text-2xl font-semibold text-gray-900">Open missions</h2>
      <p class="mt-2 text-sm text-gray-600">Review active objectives and create new assignments.</p>
    <% end %>

    <%= link_to hunters_path, class: "rounded-2xl border border-gray-200 bg-white p-6 transition hover:-translate-y-1 hover:border-indigo-400 hover:shadow-sm" do %>
      <p class="text-sm uppercase tracking-[0.3em] text-emerald-300">Hunters</p>
      <h2 class="mt-3 text-2xl font-semibold text-gray-900">Registered hunters</h2>
      <p class="mt-2 text-sm text-gray-600">Track available hunters and onboard new talent.</p>
    <% end %>

    <%= link_to bounties_path, class: "rounded-2xl border border-gray-200 bg-white p-6 transition hover:-translate-y-1 hover:border-indigo-400 hover:shadow-sm" do %>
      <p class="text-sm uppercase tracking-[0.3em] text-amber-300">Bounties</p>
      <h2 class="mt-3 text-2xl font-semibold text-gray-900">Available bounties</h2>
      <p class="mt-2 text-sm text-gray-600">View rewards, targets, and payout opportunities.</p>
    <% end %>
  </section>
</main>
