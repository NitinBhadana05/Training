<main class="mx-auto w-full max-w-7xl px-4 py-10 text-gray-900 sm:px-6 lg:px-8">
  <div class="mb-8">
    <p class="text-sm uppercase tracking-[0.3em] text-indigo-300">Create</p>
    <h1 class="mt-2 text-3xl font-bold text-gray-900">Choose what to add</h1>
  </div>

  <div class="grid gap-6 md:grid-cols-3">
    <%= link_to new_hunter_path, class: "rounded-3xl border border-gray-200 bg-white p-8 transition hover:-translate-y-1 hover:border-emerald-400 hover:shadow-sm" do %>
      <p class="text-sm uppercase tracking-[0.3em] text-emerald-300">Hunter</p>
      <h2 class="mt-3 text-3xl font-semibold text-gray-900">New Hunter</h2>
      <p class="mt-3 text-sm leading-6 text-gray-600">Open the hunter creation flow to register a new specialist.</p>
    <% end %>

    <%= link_to new_bounty_path, class: "rounded-3xl border border-gray-200 bg-white p-8 transition hover:-translate-y-1 hover:border-amber-400 hover:shadow-sm" do %>
      <p class="text-sm uppercase tracking-[0.3em] text-amber-300">Bounty</p>
      <h2 class="mt-3 text-3xl font-semibold text-gray-900">New Bounty</h2>
      <p class="mt-3 text-sm leading-6 text-gray-600">Open the bounty creation flow to define a new reward and target.</p>
    <% end %>

    <%= link_to new_mission_path, class: "rounded-3xl border border-gray-200 bg-white p-8 transition hover:-translate-y-1 hover:border-indigo-400 hover:shadow-sm" do %>
      <p class="text-sm uppercase tracking-[0.3em] text-indigo-300">Mission</p>
      <h2 class="mt-3 text-3xl font-semibold text-gray-900">New Mission</h2>
      <p class="mt-3 text-sm leading-6 text-gray-600">Open the mission creation flow to set up a new operation.</p>
    <% end %>
  </div>
</main>
