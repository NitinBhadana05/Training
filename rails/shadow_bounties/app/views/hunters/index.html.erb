<!-- app/views/hunters/index.html.erb -->

<div class="p-8">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-4xl font-bold text-gray-800">
      Hunters
    </h1>

    <%= link_to "New Hunter",
        new_hunter_path,
        class: "rounded-lg bg-blue-600 px-5 py-3 text-white hover:bg-blue-500" %>
  </div>

  <%= search_form_for @q do |f| %>
    <div class="mb-8 flex gap-3">
      <%= f.search_field :alias_cont,
          placeholder: "Search hunters...",
          class: "w-80 rounded-lg border border-gray-300 bg-white px-4 py-3 shadow-sm focus:border-blue-500 focus:outline-none" %>

      <%= f.submit "Search",
          class: "rounded-lg bg-gray-800 px-5 py-3 text-white hover:bg-gray-700" %>
    </div>
  <% end %>

  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    <% @hunters.each do |hunter| %>
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md">
        
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-2xl font-bold text-gray-800">
            <%= hunter.alias %>
          </h2>

          <span class="rounded-full bg-blue-100 px-3 py-1 text-sm font-medium text-blue-700">
            <%= hunter.rank %>
          </span>
        </div>

        <p class="mb-6 text-gray-500">
          Region:
          <%= hunter.region %>
        </p>

        <%= link_to "View Details",
            hunter,
            class: "inline-block rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white hover:bg-gray-700" %>
      </div>
    <% end %>
  </div>

  <div class="mt-10">
    <%== pagy_nav(@pagy) %>
  </div>
</div>