<!-- app/views/hunters/show.html.erb -->

<div class="mx-auto max-w-4xl p-8">
  <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">

    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-5xl font-bold text-gray-800">
          <%= @hunter.alias %>
        </h1>

        <p class="mt-3 text-lg text-gray-500">
          Elite supernatural bounty hunter
        </p>
      </div>

      <span class="rounded-full bg-blue-100 px-4 py-2 text-sm font-semibold text-blue-700">
        <%= @hunter.rank %>
      </span>
    </div>

    <div class="grid gap-6 md:grid-cols-2">

      <div class="rounded-xl bg-gray-100 p-6">
        <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-gray-500">
          Region
        </h2>

        <p class="text-2xl font-bold text-gray-800">
          <%= @hunter.region %>
        </p>
      </div>

      <div class="rounded-xl bg-gray-100 p-6">
        <h2 class="mb-2 text-sm font-semibold uppercase tracking-wide text-gray-500">
          Missions
        </h2>

        <p class="text-2xl font-bold text-gray-800">
          <%= @hunter.missions.count %>
        </p>
      </div>

    </div>

    <div class="mt-10 flex flex-wrap gap-4">

      <%= link_to "Edit Hunter",
          edit_hunter_path(@hunter),
          class: "rounded-lg bg-yellow-500 px-5 py-3 font-medium text-white hover:bg-yellow-400" %>

      <%= link_to "Delete Hunter",
          @hunter,
          data: {
            turbo_method: :delete,
            turbo_confirm: "Delete this hunter?"
          },
          class: "rounded-lg bg-red-600 px-5 py-3 font-medium text-white hover:bg-red-500" %>

      <%= link_to "Back",
          hunters_path,
          class: "rounded-lg bg-gray-900 px-5 py-3 font-medium text-white hover:bg-gray-700" %>

    </div>
    
  </div>
</div>