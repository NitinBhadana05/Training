<!-- app/views/missions/_form.html.erb -->

<%= form_with model: @mission,
    class: "space-y-6 rounded-2xl border border-gray-200 bg-white p-8 shadow-sm" do |f| %>

  <div>
    <%= f.label :hunter_id,
        class: "mb-2 block text-sm font-semibold text-gray-700" %>

    <%= f.collection_select :hunter_id,
        Hunter.all,
        :id,
        :alias,
        {},
        class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-blue-500 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :bounty_id,
        class: "mb-2 block text-sm font-semibold text-gray-700" %>

    <%= f.collection_select :bounty_id,
        Bounty.all,
        :id,
        :target_name,
        {},
        class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-blue-500 focus:outline-none" %>
  </div>

  <div>
    <%= f.label :completed,
        class: "mb-2 block text-sm font-semibold text-gray-700" %>

    <%= f.check_box :completed,
        class: "h-5 w-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
  </div>

  <div>
    <%= f.label :notes,
        class: "mb-2 block text-sm font-semibold text-gray-700" %>

    <%= f.text_area :notes,
        rows: 5,
        class: "w-full rounded-xl border border-gray-300 px-4 py-3 focus:border-blue-500 focus:outline-none" %>
  </div>

  <%= f.submit class: "rounded-xl bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-500" %>

<% end %>