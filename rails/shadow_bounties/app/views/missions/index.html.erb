<!-- app/views/missions/index.html.erb -->

<div class="p-8">
  <div class="mb-8 flex items-center justify-between">
    <h1 class="text-4xl font-bold text-gray-800">
      Missions
    </h1>

    <%= link_to "New Mission",
        new_mission_path,
        class: "rounded-lg bg-blue-600 px-5 py-3 text-white hover:bg-blue-500" %>
  </div>

  <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
    <table class="min-w-full">
      <thead class="bg-gray-100">
        <tr>
          <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">
            Hunter
          </th>

          <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">
            Target
          </th>

          <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">
            Completed
          </th>

          <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">
            Notes
          </th>

          <th class="px-6 py-4 text-left text-sm font-semibold text-gray-700">
            Action
          </th>
        </tr>
      </thead>

      <tbody class="divide-y divide-gray-200">
        <% @missions.each do |mission| %>
          <tr class="hover:bg-gray-50">
            
            <td class="px-6 py-4 text-gray-800">
              <%= mission.hunter.alias %>
            </td>

            <td class="px-6 py-4 text-gray-800">
              <%= mission.bounty.target_name %>
            </td>

            <td class="px-6 py-4">
              <% if mission.completed %>
                <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-700">
                  Completed
                </span>
              <% else %>
                <span class="rounded-full bg-yellow-100 px-3 py-1 text-sm font-medium text-yellow-700">
                  Pending
                </span>
              <% end %>
            </td>

            <td class="px-6 py-4 text-gray-500">
              <%= truncate(mission.notes, length: 40) %>
            </td>

            <td class="px-6 py-4">
              <%= link_to "View",
                  mission,
                  class: "rounded-lg bg-gray-900 px-4 py-2 text-sm text-white hover:bg-gray-700" %>
            </td>

          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>