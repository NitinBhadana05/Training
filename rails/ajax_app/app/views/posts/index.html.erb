<h1>Posts</h1>

<%= turbo_frame_tag "new_post" do %>
  <%= render "form", post: @post %>
<% end %>
<br>
<%= form_with url: posts_path, method: :get, data: { turbo_frame: "posts" } do |f| %>
  <%= f.text_field :query, 
        placeholder: "Search posts...", 
        oninput: "this.form.requestSubmit()" %>
<% end %><br>

<%= turbo_frame_tag "posts" do %>
  <%= render @posts %>
<% end %>


<div id="posts">
  <h3>infnite scrole start</h3>
  <% @posts.each do |post| %>
    <p><%= post.title %></p>
  <% end %>
  <h3>end</h3>
</div>

<script>
function likePost(postId) {
  fetch(`/posts/${postId}/like`, {
    method: "POST",
    headers: {
      "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content,
      "Accept": "application/json"
    }
  })
  .then(res => res.json())
  .then(data => {
    document.getElementById(`likes-${postId}`).innerText = data.likes;

    const btn = document.getElementById(`btn-${postId}`);
    btn.innerText = data.liked ? "💔" : "❤️";
  })
  .catch(() => {
    alert("Error liking post");
  });
}

document.addEventListener("DOMContentLoaded", () => {
  let offset = 10;
  let loading = false;

  window.addEventListener("scroll", () => {
    if (loading) return;

    if (window.innerHeight + window.scrollY >= document.body.offsetHeight - 100) {
      loading = true;

      fetch(`/posts?offset=${offset}`, {
        headers: { "Accept": "application/json" }
      })
      .then(res => res.json())
      .then(data => {
        const container = document.getElementById("posts");

        if (data.length === 0) return;

        data.forEach(post => {
          const div = document.createElement("div");
          div.className = "post-item";
          div.innerHTML = `<strong>${post.title}</strong>`;
          container.appendChild(div);
        });

        offset += 10;
        loading = false;
      });
    }
  });
});
</script>