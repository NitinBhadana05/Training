<h1>
    Book list
</h1>
  <p>
    <% @books.each do |book| %>

      <li>Title: <%= book.title%></li>
      <li>Author: <%= book.auther%></li>
      <br>
       <%= link_to "Edit", edit_book_path(book) %>
       <%= button_to "Delete", book_path(book), method: :delete %>
      <hr>

    <% end %>
  </p>

 