<div class="mt-6 flex flex-wrap gap-3 text-sm font-semibold text-slate-600">
  <% if controller_name != "sessions" %>
    <%= link_to "Sign in", new_session_path(resource_name), class: "rounded-full border border-slate-200 px-4 py-2 transition hover:border-coral hover:text-coral" %>
  <% end %>
  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <%= link_to "Sign up", new_registration_path(resource_name), class: "rounded-full border border-slate-200 px-4 py-2 transition hover:border-coral hover:text-coral" %>
  <% end %>
</div>
