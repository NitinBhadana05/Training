<section class="mx-auto max-w-md rounded-[2rem] border border-white/80 bg-white/90 p-6 shadow-glow sm:p-8">
  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-coral"><%= local_assigns.fetch(:eyebrow, "Account") %></p>
  <h1 class="mt-2 text-3xl font-black tracking-tight text-ink"><%= title %></h1>
  <% if local_assigns[:subtitle].present? %>
    <p class="mt-3 text-sm text-slate-500"><%= subtitle %></p>
  <% end %>
  <div class="mt-8">
    <%= yield %>
  </div>
</section>
