<%= render "devise/shared/auth_shell", title: "Sign in", subtitle: "Open your account to create posts and manage the ones you own.", eyebrow: "Welcome back" do %>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
    <div>
      <%= f.label :email, class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-coral focus:ring-2 focus:ring-orange-100" %>
    </div>

    <div>
      <%= f.label :password, class: "mb-2 block text-sm font-semibold text-slate-700" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-coral focus:ring-2 focus:ring-orange-100" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="flex items-center gap-3 text-sm text-slate-600">
        <%= f.check_box :remember_me, class: "rounded border-slate-300 text-coral focus:ring-orange-200" %>
        <span>Remember me</span>
      </label>
    <% end %>

    <%= f.submit "Sign in", class: "w-full rounded-full bg-ink px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800" %>
  <% end %>

  <%= render "devise/shared/links" %>
<% end %>
