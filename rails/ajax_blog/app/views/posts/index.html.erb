<section class="mb-8 grid gap-6 lg:grid-cols-[1.4fr_0.8fr]">
  <div class="rounded-[2rem] bg-ink px-6 py-8 text-white shadow-glow sm:px-8">
    <p class="mb-3 inline-flex rounded-full border border-white/20 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-orange-200">Public feed</p>
    <h1 class="max-w-2xl text-4xl font-black tracking-tight sm:text-5xl">Everyone can read posts. Only the owner can change them.</h1>
    <p class="mt-4 max-w-2xl text-sm text-slate-300 sm:text-base">Browse every post in the app, sign in to publish your own, and manage only the posts attached to your account.</p>
  </div>

  <div class="rounded-[2rem] border border-orange-100 bg-sand p-6 shadow-glow">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-coral">Overview</p>
    <dl class="mt-4 space-y-4">
      <div>
        <dt class="text-sm text-slate-500">Total posts</dt>
        <dd class="text-3xl font-black text-ink"><%= @posts.total_count %></dd>
      </div>
      <div>
        <dt class="text-sm text-slate-500">Access rule</dt>
        <dd class="text-lg font-semibold text-slate-800"><%= user_signed_in? ? "You can edit only your posts" : "Read-only until sign in" %></dd>
      </div>
    </dl>
  </div>
</section>

<section class="grid gap-6">
  <% if @posts.any? %>
    <% @posts.each do |post| %>
      <article class="rounded-[2rem] border border-white/80 bg-white/90 p-6 shadow-glow backdrop-blur">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
          <div class="space-y-3">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-coral"><%= post.created_at.strftime("%d %b %Y") %></p>
            <h2 class="text-2xl font-black tracking-tight text-ink">
              <%= link_to post.title, post_path(post), class: "transition hover:text-coral" %>
            </h2>
            <p class="text-sm font-semibold text-slate-500">By <%= post.user.email %></p>
            <p class="max-w-3xl text-sm leading-7 text-slate-600 sm:text-base"><%= truncate(post.content, length: 220) %></p>
          </div>

          <div class="flex flex-wrap items-center gap-3">
            <%= render "likes/count", post: post %>
            <%= render "likes/button", post: post %>
          </div>
        </div>

        <div class="mt-6 flex flex-wrap gap-3 text-sm font-semibold">
          <%= link_to "Open", post_path(post), class: "rounded-full bg-ink px-4 py-2 text-white transition hover:bg-slate-800" %>
          <% if can_manage_post?(post) %>
            <%= link_to "Edit", edit_post_path(post), class: "rounded-full border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-coral hover:text-coral" %>
            <%= link_to "Delete", post_path(post), data: { turbo_method: :delete, turbo_confirm: "Delete this post?" }, class: "rounded-full border border-red-200 px-4 py-2 text-red-600 transition hover:bg-red-50" %>
          <% end %>
        </div>
      </article>
    <% end %>

    <div class="rounded-2xl border border-white/70 bg-white/80 px-5 py-4 shadow-glow">
      <%= paginate @posts %>
    </div>
  <% else %>
    <div class="rounded-[2rem] border border-dashed border-slate-300 bg-white/70 p-12 text-center shadow-glow">
      <h2 class="text-2xl font-black tracking-tight text-ink">No posts yet</h2>
      <p class="mt-3 text-sm text-slate-500">Be the first person to publish something.</p>
      <% if user_signed_in? %>
        <%= link_to "Create post", new_post_path, class: "mt-6 inline-flex rounded-full bg-coral px-5 py-3 text-sm font-semibold text-white transition hover:bg-orange-600" %>
      <% else %>
        <%= link_to "Sign in to post", new_user_session_path, class: "mt-6 inline-flex rounded-full bg-coral px-5 py-3 text-sm font-semibold text-white transition hover:bg-orange-600" %>
      <% end %>
    </div>
  <% end %>
</section>
