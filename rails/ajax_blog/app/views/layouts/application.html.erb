<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Ajax Blog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Ajax Blog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ink: "#0f172a",
              coral: "#f97316",
              sand: "#fff7ed"
            },
            boxShadow: {
              glow: "0 24px 60px rgba(15, 23, 42, 0.12)"
            }
          }
        }
      }
    </script>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gradient-to-br from-orange-50 via-white to-slate-100 text-slate-900">
    <div class="mx-auto flex min-h-screen max-w-7xl flex-col px-4 py-6 sm:px-6 lg:px-8">
      <header class="mb-8 rounded-3xl border border-white/70 bg-white/80 px-5 py-4 shadow-glow backdrop-blur sm:px-8">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <%= link_to "Ajax Blog", root_path, class: "text-2xl font-black tracking-tight text-ink" %>
            <p class="text-sm text-slate-500">Public posts, owner-only editing, and full admin oversight in ActiveAdmin.</p>
          </div>

          <nav class="flex flex-wrap items-center gap-3 text-sm font-medium">
            <% if user_signed_in? %>
              <span class="rounded-full bg-orange-100 px-3 py-1 text-coral"><%= current_user.email %></span>
              <%= link_to "All posts", posts_path, class: "rounded-full border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-coral hover:text-coral" %>
              <%= link_to "New post", new_post_path, class: "rounded-full bg-ink px-4 py-2 text-white transition hover:bg-slate-800" %>
              <% if admin_signed_in? %>
                <%= link_to "Admin panel", admin_root_path, class: "rounded-full border border-coral/30 bg-orange-50 px-4 py-2 text-coral transition hover:bg-orange-100" %>
              <% end %>
              <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "rounded-full border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-red-300 hover:text-red-600" %>
            <% else %>
              <%= link_to "Browse posts", posts_path, class: "rounded-full border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-coral hover:text-coral" %>
              <%= link_to "Sign in", new_user_session_path, class: "rounded-full border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-coral hover:text-coral" %>
              <%= link_to "Sign up", new_user_registration_path, class: "rounded-full bg-coral px-4 py-2 text-white transition hover:bg-orange-600" %>
              <%= link_to "Admin", new_admin_user_session_path, class: "rounded-full border border-slate-200 px-4 py-2 text-slate-700 transition hover:border-slate-400" %>
            <% end %>
          </nav>
        </div>
      </header>

      <% flash.each do |type, message| %>
        <% alert_classes = type.to_s == "notice" ? "border-emerald-200 bg-emerald-50 text-emerald-800" : "border-red-200 bg-red-50 text-red-700" %>
        <div class="mb-6 rounded-2xl border px-4 py-3 text-sm font-medium <%= alert_classes %>"><%= message %></div>
      <% end %>

      <main class="flex-1">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
