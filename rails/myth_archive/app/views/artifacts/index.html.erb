

<h1>Artifacts</h1>

<%= link_to "New Artifact", new_explorer_artifact_path(@explorer) %>

<hr>

<%= search_form_for @q,
    url: explorer_artifacts_path(@explorer),
    method: :get do |f| %>

  <div>
    <%= f.label :name_cont, "Search Name" %>
    <%= f.search_field :name_cont %>
  </div>

  <div>
    <%= f.label :origin_country_cont, "Country" %>
    <%= f.search_field :origin_country_cont %>
  </div>

  <%= f.submit "Search" %>
<% end %>

<hr>

<% @artifacts.each do |artifact| %>
  <div>
    <h3><%= artifact.name %></h3>

    <p><%= artifact.description %></p>

    <p>
      Danger Level:
      <%= artifact.danger_level %>
    </p>

    <% if artifact.image.present? %>
      <%= image_tag artifact.image.url(:thumb) %>
    <% end %>

    <br>

    <%= link_to "Show",
        explorer_artifact_path(@explorer, artifact) %>

    <%= link_to "Edit",
        edit_explorer_artifact_path(@explorer, artifact) %>

    <%= link_to "Delete",
        explorer_artifact_path(@explorer, artifact),
        data: {
          turbo_method: :delete,
          turbo_confirm: "Are you sure?"
        } %>
  </div>

  <hr>
<% end %>

<%= pagy_nav(@pagy).html_safe %>