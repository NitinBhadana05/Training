<section class="space-y-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-sky-700">Admin</p>
      <h1 class="mt-2 text-4xl font-semibold tracking-tight text-slate-900">Users</h1>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row">
      <%= form_with url: users_path, method: :get, class: "flex items-center gap-3", local: true do |form| %>
        <%= form.text_field :query, value: @query, placeholder: "Search by name or email", class: "rounded-full border border-slate-300 bg-white px-5 py-3 text-sm outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %>
        <%= form.submit "Search", class: "inline-flex cursor-pointer items-center rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-900 ring-1 ring-slate-300 transition hover:bg-slate-50" %>
      <% end %>
      <%= link_to "Create user", new_user_path, class: "inline-flex items-center rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-700" %>
    </div>
  </div>

  <div class="overflow-hidden rounded-[2rem] bg-white shadow-sm ring-1 ring-slate-200">
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Name</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Email</th>
          <th class="px-6 py-4 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Role</th>
          <th class="px-6 py-4"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @users.each do |user| %>
          <tr>
            <td class="px-6 py-4 font-medium text-slate-900"><%= user.full_name %></td>
            <td class="px-6 py-4 text-slate-600"><%= user.email_address %></td>
            <td class="px-6 py-4 text-slate-600"><%= user.role.capitalize %></td>
            <td class="px-6 py-4 text-right">
              <div class="flex justify-end gap-3">
                <%= link_to "View", user_path(user), class: "font-medium text-sky-700 hover:text-sky-900" %>
                <%= link_to "Edit", edit_user_path(user), class: "font-medium text-slate-700 hover:text-slate-900" %>
                <%= button_to "Delete", user_path(user), method: :delete, class: "font-medium text-red-700 hover:text-red-900", form: { data: { turbo_confirm: "Delete this user?" }, class: "inline" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
