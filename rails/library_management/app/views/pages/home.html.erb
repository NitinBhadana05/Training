<div class="space-y-8">
  <section class="rounded-[2rem] bg-slate-900 px-8 py-10 text-white shadow-xl">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="max-w-3xl space-y-4">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-amber-300">Dashboard</p>
        <h1 class="text-4xl font-semibold tracking-tight sm:text-5xl">
          Hello, <%= current_user.full_name %>. 
        </h1>
        <p class="text-lg text-slate-300">
          Review circulation, monitor inventory movement, and follow billing activity through a role-based operational dashboard built for routine institutional use.
        </p>
      </div>
      <div class="rounded-3xl bg-white/10 px-6 py-5 backdrop-blur">
        <p class="text-sm text-slate-300">Signed in as</p>
        <p class="mt-2 text-2xl font-semibold"><%= current_user.role.capitalize %></p>
      </div>
    </div>
  </section>

  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <p class="text-sm text-slate-500">Total books</p>
      <p class="mt-3 text-4xl font-semibold text-slate-900"><%= @book_count %></p>
    </div>
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <p class="text-sm text-slate-500">Available books</p>
      <p class="mt-3 text-4xl font-semibold text-slate-900"><%= @available_books_count %></p>
    </div>
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <p class="text-sm text-slate-500">Active issues</p>
      <p class="mt-3 text-4xl font-semibold text-slate-900"><%= @active_issue_count %></p>
    </div>
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <p class="text-sm text-slate-500">Overdue issues</p>
      <p class="mt-3 text-4xl font-semibold text-slate-900"><%= @overdue_issue_count %></p>
    </div>
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <p class="text-sm text-slate-500">Pending billing</p>
      <p class="mt-3 text-4xl font-semibold text-slate-900"><%= number_to_currency(@pending_bill_total) %></p>
    </div>
  </section>

  <section class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
    <div class="rounded-[2rem] bg-white p-8 shadow-sm ring-1 ring-slate-200">
      <div class="flex items-center justify-between">
        <h2 class="text-2xl font-semibold text-slate-900">Recent issues</h2>
        <%= link_to "View all", issues_path, class: "text-sm font-medium text-sky-700 hover:text-sky-900" %>
      </div>
      <div class="mt-6 space-y-4">
        <% @recent_issues.each do |issue| %>
          <article class="rounded-3xl border border-slate-200 p-5">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-lg font-semibold text-slate-900"><%= issue.book.title %></p>
                <p class="mt-1 text-sm text-slate-500"><%= issue.user.full_name %> • <%= issue.transaction_type.capitalize %></p>
              </div>
              <span class="rounded-full px-3 py-1 text-xs font-semibold <%= issue.overdue? ? "bg-red-100 text-red-700" : "bg-slate-100 text-slate-700" %>">
                <%= issue.status.humanize %>
              </span>
            </div>
            <div class="mt-3 flex items-center justify-between text-sm text-slate-500">
              <span><%= issue.issue_date.strftime("%d %b %Y") %></span>
              <%= link_to "Details", issue_path(issue), class: "font-medium text-sky-700 hover:text-sky-900" %>
            </div>
          </article>
        <% end %>
      </div>
    </div>

    <div class="space-y-8">
      <div class="rounded-[2rem] bg-white p-8 shadow-sm ring-1 ring-slate-200">
        <div class="flex items-center justify-between">
          <h2 class="text-2xl font-semibold text-slate-900">Recent bills</h2>
          <%= link_to "View all", bills_path, class: "text-sm font-medium text-sky-700 hover:text-sky-900" %>
        </div>
        <div class="mt-6 space-y-4">
          <% @recent_bills.each do |bill| %>
            <div class="rounded-3xl border border-slate-200 p-5">
              <p class="font-semibold text-slate-900"><%= bill.issue.book.title %></p>
              <p class="mt-1 text-sm text-slate-500"><%= bill.user.full_name %> • <%= number_to_currency(bill.total_amount) %></p>
            </div>
          <% end %>
        </div>
      </div>

      <% if admin_user? %>
        <div class="rounded-[2rem] bg-white p-8 shadow-sm ring-1 ring-slate-200">
          <div class="flex items-center justify-between">
            <h2 class="text-2xl font-semibold text-slate-900">Recent users</h2>
            <%= link_to "Manage users", users_path, class: "text-sm font-medium text-sky-700 hover:text-sky-900" %>
          </div>
          <div class="mt-6 space-y-4">
            <% @recent_users.each do |user| %>
              <div class="rounded-3xl border border-slate-200 p-5">
                <p class="font-semibold text-slate-900"><%= user.full_name %></p>
                <p class="mt-1 text-sm text-slate-500"><%= user.email_address %> • <%= user.role.capitalize %></p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>
</div>
