<section class="mx-auto max-w-3xl rounded-[2rem] bg-white p-8 shadow-sm ring-1 ring-slate-200">
  <div class="mb-8">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-sky-700">Admin</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight text-slate-900">Edit bill</h1>
  </div>

  <%= form_with model: @bill, class: "space-y-6" do |form| %>
    <% if @bill.errors.any? %>
      <div class="rounded-3xl border border-red-200 bg-red-50 p-4 text-sm text-red-700"><%= @bill.errors.full_messages.to_sentence %></div>
    <% end %>

    <div class="grid gap-6 sm:grid-cols-2">
      <div>
        <%= form.label :status, class: "text-sm font-medium text-slate-700" %>
        <%= form.select :status, Bill.statuses.keys.map { |value| [value.capitalize, value] }, {}, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %>
      </div>
      <div>
        <%= form.label :paid_on, class: "text-sm font-medium text-slate-700" %>
        <%= form.date_field :paid_on, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %>
      </div>
      <div class="sm:col-span-2">
        <%= form.label :billed_on, class: "text-sm font-medium text-slate-700" %>
        <%= form.date_field :billed_on, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %>
      </div>
      <div class="sm:col-span-2">
        <%= form.label :notes, class: "text-sm font-medium text-slate-700" %>
        <%= form.text_area :notes, rows: 5, class: "mt-2 block w-full rounded-3xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %>
      </div>
    </div>

    <div class="flex items-center gap-4">
      <%= form.submit "Update bill", class: "inline-flex cursor-pointer items-center rounded-full bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-700" %>
      <%= link_to "Back to bills", bills_path, class: "text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  <% end %>
</section>
