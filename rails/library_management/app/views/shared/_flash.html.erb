<div class="mb-6 space-y-3">
  <% if notice.present? %>
    <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700"><%= notice %></div>
  <% end %>
  <% if alert.present? %>
    <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-700"><%= alert %></div>
  <% end %>
</div>
