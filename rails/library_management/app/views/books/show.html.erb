<section class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
  <article class="rounded-[2rem] bg-white p-8 shadow-sm ring-1 ring-slate-200">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-sky-700"><%= @book.category_label %></p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight text-slate-900"><%= @book.title %></h1>
    <p class="mt-2 text-lg text-slate-500">by <%= @book.author %></p>
    <p class="mt-8 leading-7 text-slate-600"><%= @book.description %></p>
  </article>

  <aside class="space-y-6">
    <div class="rounded-[2rem] bg-white p-8 shadow-sm ring-1 ring-slate-200">
      <h2 class="text-2xl font-semibold text-slate-900">Inventory and pricing</h2>
      <dl class="mt-6 space-y-4">
        <div class="flex items-center justify-between text-sm"><dt class="text-slate-500">ISBN</dt><dd class="font-semibold text-slate-900"><%= @book.isbn %></dd></div>
        <div class="flex items-center justify-between text-sm"><dt class="text-slate-500">Total copies</dt><dd class="font-semibold text-slate-900"><%= @book.total_copies %></dd></div>
        <div class="flex items-center justify-between text-sm"><dt class="text-slate-500">Available copies</dt><dd class="font-semibold text-slate-900"><%= @book.available_copies %></dd></div>
        <div class="flex items-center justify-between text-sm"><dt class="text-slate-500">Daily rent</dt><dd class="font-semibold text-slate-900"><%= number_to_currency(@book.daily_rent) %></dd></div>
        <div class="flex items-center justify-between text-sm"><dt class="text-slate-500">Purchase price</dt><dd class="font-semibold text-slate-900"><%= number_to_currency(@book.purchase_price) %></dd></div>
      </dl>
      <div class="mt-6 flex flex-wrap gap-3">
        <% if current_user.user? %>
          <%= button_to "Rent this book", rent_book_path(@book), method: :post, class: "inline-flex cursor-pointer items-center rounded-full bg-amber-400 px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-amber-300", disabled: !@book.available_for_checkout? %>
          <%= button_to "Buy this book", buy_book_path(@book), method: :post, class: "inline-flex cursor-pointer items-center rounded-full bg-emerald-400 px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-emerald-300", disabled: !@book.available_for_checkout? %>
        <% else %>
          <%= link_to "Edit book", edit_book_path(@book), class: "inline-flex items-center rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-700" %>
          <%= button_to "Delete book", book_path(@book), method: :delete, class: "inline-flex cursor-pointer items-center rounded-full border border-red-200 px-5 py-3 text-sm font-semibold text-red-700 transition hover:bg-red-50", form: { data: { turbo_confirm: "Delete this book?" } } %>
        <% end %>
      </div>
    </div>
  </aside>
</section>
