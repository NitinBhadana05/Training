<section class="space-y-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div>
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-sky-700">Catalog</p>
      <h1 class="mt-2 text-4xl font-semibold tracking-tight text-slate-900">Books</h1>
    </div>
    <div class="flex flex-col gap-3 sm:flex-row">
      <%= form_with url: books_path, method: :get, class: "flex flex-wrap items-center gap-3", local: true do |form| %>
        <%= form.text_field :query, value: @query, placeholder: "Search title, author, ISBN, or category", class: "rounded-full border border-slate-300 bg-white px-5 py-3 text-sm outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %>
        <%= form.select :category, options_for_select([["All categories", ""]] + @categories.map { |category| [category, category] }, @selected_category), {}, class: "rounded-full border border-slate-300 bg-white px-5 py-3 text-sm outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %>
        <%= form.select :availability, options_for_select([["Any stock", ""], ["Available only", "available"]], @selected_availability), {}, class: "rounded-full border border-slate-300 bg-white px-5 py-3 text-sm outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %>
        <%= form.submit "Filter", class: "inline-flex cursor-pointer items-center rounded-full bg-white px-5 py-3 text-sm font-semibold text-slate-900 ring-1 ring-slate-300 transition hover:bg-slate-50" %>
      <% end %>
      <% if admin_user? %>
        <%= link_to "Add book", new_book_path, class: "inline-flex items-center rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-700" %>
      <% end %>
    </div>
  </div>

  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    <% @books.each do |book| %>
      <article class="flex h-full flex-col rounded-[2rem] bg-white p-6 shadow-sm ring-1 ring-slate-200">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.2em] text-sky-700"><%= book.category_label %></p>
            <h2 class="mt-2 text-2xl font-semibold text-slate-900"><%= book.title %></h2>
            <p class="mt-1 text-slate-500">by <%= book.author %></p>
          </div>
          <span class="rounded-full px-3 py-1 text-xs font-semibold <%= book.available_for_checkout? ? "bg-emerald-100 text-emerald-700" : "bg-slate-100 text-slate-500" %>">
            <%= book.available_for_checkout? ? "Available" : "Out of stock" %>
          </span>
        </div>

        <p class="mt-4 flex-1 text-sm leading-6 text-slate-600"><%= truncate(book.description, length: 150) %></p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= link_to "View", book_path(book), class: "inline-flex items-center rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-700" %>
          <% if current_user.user? %>
            <%= button_to "Rent", rent_book_path(book), method: :post, class: "inline-flex cursor-pointer items-center rounded-full bg-amber-400 px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-amber-300", disabled: !book.available_for_checkout? %>
            <%= button_to "Buy", buy_book_path(book), method: :post, class: "inline-flex cursor-pointer items-center rounded-full bg-emerald-400 px-5 py-3 text-sm font-semibold text-slate-900 transition hover:bg-emerald-300", disabled: !book.available_for_checkout? %>
          <% else %>
            <%= link_to "Edit", edit_book_path(book), class: "inline-flex items-center rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
            <%= button_to "Delete", book_path(book), method: :delete, class: "inline-flex cursor-pointer items-center rounded-full border border-red-200 px-5 py-3 text-sm font-semibold text-red-700 transition hover:bg-red-50", form: { data: { turbo_confirm: "Delete this book?" } } %>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
</section>
