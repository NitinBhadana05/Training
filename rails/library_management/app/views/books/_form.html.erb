<%= form_with model: book, class: "space-y-6" do |form| %>
  <% if book.errors.any? %>
    <div class="rounded-3xl border border-red-200 bg-red-50 p-4 text-sm text-red-700"><%= book.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="grid gap-6 sm:grid-cols-2">
    <div class="sm:col-span-2"><%= form.label :title, class: "text-sm font-medium text-slate-700" %><%= form.text_field :title, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %></div>
    <div><%= form.label :author, class: "text-sm font-medium text-slate-700" %><%= form.text_field :author, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %></div>
    <div><%= form.label :isbn, class: "text-sm font-medium text-slate-700" %><%= form.text_field :isbn, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %></div>
    <div><%= form.label :category, class: "text-sm font-medium text-slate-700" %><%= form.text_field :category, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %></div>
    <div><%= form.label :daily_rent, class: "text-sm font-medium text-slate-700" %><%= form.number_field :daily_rent, step: 0.01, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %></div>
    <div><%= form.label :purchase_price, class: "text-sm font-medium text-slate-700" %><%= form.number_field :purchase_price, step: 0.01, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %></div>
    <div><%= form.label :total_copies, class: "text-sm font-medium text-slate-700" %><%= form.number_field :total_copies, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %></div>
    <div><%= form.label :available_copies, class: "text-sm font-medium text-slate-700" %><%= form.number_field :available_copies, class: "mt-2 block w-full rounded-2xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %></div>
    <div class="sm:col-span-2"><%= form.label :description, class: "text-sm font-medium text-slate-700" %><%= form.text_area :description, rows: 6, class: "mt-2 block w-full rounded-3xl border border-slate-300 px-4 py-3 outline-none focus:border-sky-500 focus:ring-2 focus:ring-sky-200" %></div>
    <div class="sm:col-span-2">
      <label class="inline-flex items-center gap-3 text-sm font-medium text-slate-700">
        <%= form.check_box :active, class: "h-5 w-5 rounded border-slate-300 text-sky-600 focus:ring-sky-200" %>
        Available for circulation
      </label>
    </div>
  </div>

  <div class="flex items-center gap-4">
    <%= form.submit class: "inline-flex cursor-pointer items-center rounded-full bg-slate-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-slate-700" %>
    <%= link_to "Back to books", books_path, class: "text-sm font-medium text-slate-600 hover:text-slate-900" %>
  </div>
<% end %>
