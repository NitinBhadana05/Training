<h1 class="text-2xl font-bold mb-6 text-center">New Book</h1>

<div class="max-w-md mx-auto bg-white p-6 rounded-2xl shadow-md">
  <%= form_with model: @book, class: "space-y-4" do |f| %>

    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :title, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :author, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :author, class: "mt-1 w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.submit "Create Book", class: "w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition" %>
    </div>

  <% end %>
</div>