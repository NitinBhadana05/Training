<% content_for :title do %>
  Posts List
<% end %>

<h2>All Posts</h2>

<%= render partial: "post", collection: @posts %>

<%= form_with model: Post.new do |f| %>
  <p>
    <%= f.text_field :title, placeholder: "Title" %>
  </p>
  <p>
    <%= f.text_area :body, placeholder: "Body" %>
  </p>
  <%= f.submit "Create Post" %>
<% end %>