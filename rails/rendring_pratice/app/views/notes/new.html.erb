<h1 class="text-2xl font-bold text-center mb-6">New Note</h1>

<div class="max-w-md mx-auto bg-white p-6 rounded-2xl shadow">
  <%= form_with model: @note, class: "space-y-4" do |f| %>

    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :title, class: "w-full mt-1 px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= f.label :content, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :content, class: "w-full mt-1 px-3 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="flex items-center space-x-2">
      <%= f.check_box :important %>
      <%= f.label :important, class: "text-gray-700" %>
    </div>

    <%= f.submit "Create Note", class: "w-full bg-blue-600 text-white py-2 rounded-lg hover:bg-blue-700 transition" %>

  <% end %>
</div>