<div class="max-w-xl mx-auto bg-white p-6 rounded-2xl shadow mt-6">
  <h1 class="text-2xl font-bold mb-4"><%= @note.title %></h1>

  <p class="text-gray-700 mb-4"><%= @note.content %></p>

  <p class="text-sm">
    <span class="font-semibold">Important:</span>
    <span class="<%= @note.important ? 'text-green-600' : 'text-red-500' %>">
      <%= @note.important ? "Yes" : "No" %>
    </span>
  </p>
</div>