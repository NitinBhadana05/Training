<h1 class="text-2xl font-bold text-center mb-6">Important Notes</h1>

<div class="max-w-xl mx-auto space-y-4">
  <% @notes.each do |note| %>
    <div class="p-4 bg-white shadow rounded-xl hover:shadow-md transition">
      <h2 class="text-lg font-semibold">
        <%= link_to note.title, note_path(note), class: "text-blue-600 hover:underline" %>
      </h2>
    </div>
  <% end %>
</div>