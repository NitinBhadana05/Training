<div class="p-6">
  <h1 class="text-2xl font-bold mb-4">🚗 Smart Parking Dashboard</h1>

  <!-- Start Parking -->
  <div class="bg-white p-4 rounded shadow mb-6">
    <h2 class="text-xl font-semibold mb-2">Start Parking</h2>

    <%= form_with url: parking_sessions_path, method: :post, local: true do |f| %>
      <div class="mb-2">
        <%= label_tag :vehicle_number %>
        <%= text_field_tag :vehicle_number, nil, class: "border p-2 w-full" %>
      </div>

      <div class="mb-2">
        <%= label_tag :parking_slot_id, "Select Slot" %>
        <%= select_tag :parking_slot_id,
              options_from_collection_for_select(@slots, :id, :slot_number),
              class: "border p-2 w-full" %>
      </div>

      <%= submit_tag "Start Parking", class: "bg-green-500 text-white px-4 py-2 rounded" %>
    <% end %>
  </div>

  <!-- Active Sessions -->
  <div class="bg-white p-4 rounded shadow">
    <h2 class="text-xl font-semibold mb-2">Active Sessions</h2>

    <div class="overflow-x-auto">
    <table class="w-full table-auto border-collapse border border-gray-300">
      <thead>
        <tr class="bg-gray-200">
          <th class="border border-gray-300 p-2 text-left">Vehicle</th>
          <th class="border border-gray-300 p-2 text-left">Slot</th>
          <th class="border border-gray-300 p-2 text-left">Entry Time</th>
          <th class="border border-gray-300 p-2 text-left">Action</th>
        </tr>
      </thead>

      <tbody>
        <% @active_sessions.each do |s| %>
          <tr>
            <td class="border border-gray-300 p-2 align-middle"><%= s.vehicle.vehicle_number %></td>
            <td class="border border-gray-300 p-2 align-middle"><%= s.parking_slot.slot_number %></td>
            <td class="border border-gray-300 p-2 align-middle whitespace-nowrap"><%= s.entry_time %></td>
            <td class="border border-gray-300 p-2 align-middle">
              <%= button_to "End",
                    end_parking_parking_session_path(s),
                    method: :patch,
                    class: "bg-red-500 text-white px-3 py-1 rounded",
                    form: { class: "inline-block m-0" } %>
            </td>
          </tr>
        <% end %>

        <% if @active_sessions.empty? %>
          <tr>
            <td colspan="4" class="border border-gray-300 p-2 text-center text-gray-500">No active sessions</td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>

  <div class="bg-white p-4 rounded shadow mt-6">
    <h2 class="text-xl font-semibold mb-2">Completed Sessions</h2>

    <div class="overflow-x-auto">
    <table class="w-full table-auto border-collapse border border-gray-300">
      <thead>
        <tr class="bg-gray-200">
          <th class="border border-gray-300 p-2 text-left">Vehicle</th>
          <th class="border border-gray-300 p-2 text-left">Slot</th>
          <th class="border border-gray-300 p-2 text-left">Duration</th>
          <th class="border border-gray-300 p-2 text-left">Amount</th>
          <th class="border border-gray-300 p-2 text-left">Status</th>
          <th class="border border-gray-300 p-2 text-left">Paid At</th>
          <th class="border border-gray-300 p-2 text-left">Payment</th>
        </tr>
      </thead>

      <tbody>
        <% @completed_sessions.each do |s| %>
          <% payment = s.payment %>
          <tr>
            <td class="border border-gray-300 p-2 align-middle"><%= s.vehicle.vehicle_number %></td>
            <td class="border border-gray-300 p-2 align-middle"><%= s.parking_slot.slot_number %></td>
            <td class="border border-gray-300 p-2 align-middle"><%= s.duration %> hour(s)</td>
            <td class="border border-gray-300 p-2 align-middle whitespace-nowrap">₹<%= payment&.amount || 0 %></td>
            <td class="border border-gray-300 p-2 align-middle"><%= payment&.payment_status || "pending" %></td>
            <td class="border border-gray-300 p-2 align-middle whitespace-nowrap"><%= payment&.paid_at || "-" %></td>
            <td class="border border-gray-300 p-2 align-middle">
              <% if payment.present? && payment.payment_status != "paid" %>
                <%= button_to "Pay Now",
                      pay_payment_path(payment),
                      method: :patch,
                      class: "bg-blue-500 text-white px-3 py-1 rounded",
                      form: { class: "inline-block m-0" } %>
              <% elsif payment.present? %>
                <%= link_to "View Payment", payment_path(payment), class: "text-blue-600 underline" %>
              <% else %>
                Pending
              <% end %>
            </td>
          </tr>
        <% end %>

        <% if @completed_sessions.empty? %>
          <tr>
            <td colspan="7" class="border border-gray-300 p-2 text-center text-gray-500">No completed sessions</td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>
</div>
