<h1>Edit User</h1>

<form action="/users/<%= @user.id %>" method="post">
  
  <input type="hidden" name="_method" value="patch">

  <input type="text" name="user[name]" value="<%= @user.name %>"><br><br>

  <input type="email" name="user[email]" value="<%= @user.email %>"><br><br>

  <input type="text" name="user[phone]" value="<%= @user.phone %>"><br><br>

  <button type="submit">Update</button>
</form>

<a href="/users">Back</a>
